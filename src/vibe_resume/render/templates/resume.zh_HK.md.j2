{# Hong Kong bilingual CV (English + 繁體中文).
   Design basis — docs/resume_locales.md §9b:
   - Bilingual section headings so the same doc works for EN-speaking and
     Chinese-speaking reviewers in one pass (FSI / Big-4 / MNCs).
   - Body text follows profile._zh_HK overrides; otherwise canonical EN
     leaks through. Use both e.g. `title` + `title_zh_HK` when you want
     truly bilingual body text.
   - Photo is optional in HK (not a default expectation).
   - HKID is NEVER on a CV — only emitted during offer stage on paper forms.
   - CEFR-style language proficiency expected (Cantonese / English / Mandarin
     as 3 separate entries is customary).
-#}
# {{ profile.name }}{% if (profile | localized('name')) and (profile | localized('name')) != profile.name %}　·　{{ profile | localized('name') }}{% endif %}
{% set _title = (profile | localized('title')) or profile.title %}
{% if _title %}**{{ _title }}**{% endif %}

{% set primary = [] -%}
{%- set _loc = (profile | localized('location')) or profile.location -%}
{%- if _loc %}{%- set _ = primary.append(_loc) %}{% endif %}
{%- if profile.email %}{%- set _ = primary.append(profile.email) %}{% endif %}
{%- if profile.phone %}{%- set _ = primary.append(profile.phone) %}{% endif %}
{{ primary | join(' | ') }}
{% set links = [] -%}
{%- if profile.linkedin %}{%- set _ = links.append('LinkedIn: ' ~ profile.linkedin) %}{% endif %}
{%- if profile.github %}{%- set _ = links.append('GitHub: ' ~ profile.github) %}{% endif %}
{%- if profile.website %}{%- set _ = links.append(profile.website) %}{% endif %}
{% if links %}{{ links | join(' | ') }}
{% endif %}

{% set _target = (profile | localized('target_role')) or profile.target_role %}
{% if _target %}> **{{ T.target_role }}**: {{ _target }}
{% endif %}

{% set _summary = (profile | localized('summary')) or profile.summary %}
{% if _summary %}
## {{ T.summary }}
{{ _summary | trim }}
{% endif %}

{% if skills_grouped %}
## {{ T.skills }}
{% for cat, items in skills_grouped.items() %}- **{{ cat }}**: {{ items | join(', ') }}
{% endfor %}
{% endif %}

{% if profile.experience %}
## {{ T.experience }}

{% for e in profile.experience if e.title or e.company %}
### {{ e | localized('title') }} — {{ e | localized('company') }}
_{{ e.start | date }} – {{ e.end | date }}_

{% for b in (e | localized('bullets')) or [] %}- {{ b }}
{% endfor %}

{% endfor %}
{% endif %}

## {{ T.projects }}
{% set w30 = window_stats.get('last_30d') %}
{% if total_sessions > 0 %}
_Aggregated from {{ ai_overview | map(attribute='tool') | join(' / ') }} across {{ groups|length }} projects · {{ total_sessions }} AI-assisted sessions · {{ timespan_start | date }} – {{ timespan_end | date }}{% if w30 and w30.sessions > 0 %}; last 30 days: {{ w30.active_days }}/{{ w30.window_days }} active, longest streak {{ w30.longest_streak_days }}d{% endif %}{% if top_capabilities %}. {{ T.capabilities }}: {{ top_capabilities | join(', ') }}{% endif %}._
{% endif %}

{% set top_n = 6 %}
{% for g in groups[:top_n] %}
### {{ loop.index }}. {{ g.name }}{% if g.headline %} — _{{ g.headline }}_{% endif %}

- **{{ T.period }}**: {{ g.first_activity[:10] | date }} – {{ g.last_activity[:10] | date }} | **{{ T.sessions }}**: {{ g.total_sessions }} | **{{ T.breadth }}**: {{ g.capability_breadth }}
{% if g.tech_stack %}- **{{ T.stack }}**: {{ g.tech_stack | join(', ') }}
{% endif %}
{% if g.domain_tags %}- **{{ T.domain_tags }}**: {{ g.domain_tags | join(', ') }}
{% endif %}
{% if g.achievements %}
**{{ T.key_achievements }}**

{% for a in g.achievements %}- {{ a }}
{% endfor %}
{% elif g.summary %}
{{ g.summary }}
{% endif %}

{% endfor %}

{% if groups|length > top_n %}
### {{ T.other_short }} ({{ groups|length - top_n }})
{% for g in groups[top_n:] %}- **{{ g.name }}** ({{ g.first_activity[:10] }}; {{ g.capability_breadth }} areas{% if g.tech_stack %}; {{ g.tech_stack[:3] | join(', ') }}{% endif %})
{% endfor %}
{% endif %}

{% if profile.education %}
## {{ T.education }}
{% for ed in profile.education if ed.degree or ed.school %}- **{{ ed.degree }}**, {{ ed.school }} ({{ ed.year }})
{% endfor %}
{% endif %}

{% if profile.certifications %}
## {{ T.certifications }}
{% for c in profile.certifications %}- {{ c.name }} ({{ c.year }})
{% endfor %}
{% endif %}

{% if profile.languages %}
## {{ T.languages }}
_CEFR scale (A1 basic → C2 native). HK employers commonly expect Cantonese / English / Mandarin listed separately._
{% for lang in profile.languages %}- {{ lang }}
{% endfor %}
{% endif %}

{% if profile.custom_sections %}
{% set awards = profile.custom_sections.get('awards') %}
{% if awards %}
## {{ T.awards }}
{% for item in awards %}- {{ item }}
{% endfor %}
{% endif %}
{% set talks = profile.custom_sections.get('talks') %}
{% if talks %}
## {{ T.talks }}
{% for item in talks %}- {{ item }}
{% endfor %}
{% endif %}
{% set hobbies = profile.custom_sections.get('hobbies') %}
{% if hobbies %}
## {{ T.hobbies }}
{% for item in hobbies %}- {{ item }}
{% endfor %}
{% endif %}
{% endif %}

{% if tailored_for %}
---
_{{ T.tailored_for }}: {{ tailored_for }}_
{% endif %}
