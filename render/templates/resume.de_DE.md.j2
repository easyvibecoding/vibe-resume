{# Lebenslauf — German conventions:
   - Persönliche Daten as a labeled list (not centered contact strip)
   - Berufserfahrung in reverse chronological with company-first title line
   - Photo expected (right-aligned in DOCX); markdown skips it
   - Optional Geburtsdatum / Nationalität / Familienstand from profile
   - Noun-phrase, fact-first; no marketing verbs
-#}
# {{ (profile | localized('name')) or profile.name }}
{% set _title = (profile | localized('title')) or profile.title %}
{% if _title %}_{{ _title }}_{% endif %}

## Persönliche Daten
{% set _loc = (profile | localized('location')) or profile.location %}
{% if _loc %}- **Adresse**: {{ _loc }}
{% endif %}
{% if profile.email %}- **E-Mail**: {{ profile.email }}
{% endif %}
{% if profile.phone %}- **Telefon**: {{ profile.phone }}
{% endif %}
{% if profile.dob %}- **Geburtsdatum**: {{ profile.dob | date }}
{% endif %}
{% if profile.nationality %}- **Nationalität**: {{ profile.nationality }}
{% endif %}
{% if profile.linkedin %}- **LinkedIn**: {{ profile.linkedin }}
{% endif %}
{% if profile.github %}- **GitHub**: {{ profile.github }}
{% endif %}

{% set _target = (profile | localized('target_role')) or profile.target_role %}
{% if _target %}> **{{ T.target_role }}**: {{ _target }}
{% endif %}

{% set _summary = (profile | localized('summary')) or profile.summary %}
{% if _summary %}
## {{ T.summary }}
{{ _summary | trim }}
{% endif %}

{% if profile.experience %}
## {{ T.experience }}

{% for e in profile.experience if e.title or e.company %}
**{{ e.start | date }} – {{ e.end | date }}**　{{ e | localized('company') }}
_{{ e | localized('title') }}_

{% for b in (e | localized('bullets')) or [] %}- {{ b }}
{% endfor %}

{% endfor %}
{% endif %}

## {{ T.projects }}
{% set w30 = window_stats.get('last_30d') %}
_{{ ai_overview | map(attribute='tool') | join(' / ') }} eingesetzt — {{ groups|length }} Projekte mit insgesamt {{ total_sessions }} Sessions ({{ timespan_start | date }} – {{ timespan_end | date }}){% if w30 and w30.sessions > 0 %}; letzte 30 Tage: {{ w30.active_days }}/{{ w30.window_days }} aktive Tage, längste Serie {{ w30.longest_streak_days }} Tage{% endif %}{% if top_capabilities %}; {{ T.capabilities }}: {{ top_capabilities | join(' · ') }}{% endif %}._

{% set top_n = 6 %}
{% for g in groups[:top_n] %}
### {{ loop.index }}. {{ g.name }}{% if g.headline %} — _{{ g.headline }}_{% endif %}

- **{{ T.period }}**: {{ g.first_activity[:10] | date }} – {{ g.last_activity[:10] | date }}　|　**{{ T.sessions }}**: {{ g.total_sessions }}　|　**{{ T.breadth }}**: {{ g.capability_breadth }} Bereiche
{% if g.tech_stack %}- **{{ T.stack }}**: {{ g.tech_stack | join(', ') }}
{% endif %}
{% if g.domain_tags %}- **{{ T.domain_tags }}**: {{ g.domain_tags | join(', ') }}
{% endif %}
{% if g.achievements %}
**{{ T.key_achievements }}**

{% for a in g.achievements %}- {{ a }}
{% endfor %}
{% elif g.summary %}
{{ g.summary }}
{% endif %}

{% endfor %}

{% if groups|length > top_n %}
### {{ T.other_short }} ({{ groups|length - top_n }})
{% for g in groups[top_n:] %}- **{{ g.name }}** ({{ g.first_activity[:10] | date }}; {{ g.capability_breadth }} Bereiche{% if g.tech_stack %}; {{ g.tech_stack[:3] | join(', ') }}{% endif %})
{% endfor %}
{% endif %}

{% if profile.education %}
## {{ T.education }}
{% for ed in profile.education if ed.degree or ed.school %}- **{{ ed.degree }}** — {{ ed.school }} ({{ ed.year }})
{% endfor %}
{% endif %}

{% if profile.certifications %}
## {{ T.certifications }}
{% for c in profile.certifications %}- {{ c.name }} ({{ c.year }})
{% endfor %}
{% endif %}

{% if profile.languages %}
## Sprachen
{% for lang in profile.languages %}- {{ lang }}
{% endfor %}
{% endif %}

{% if profile.custom_sections %}
{% set awards = profile.custom_sections.get('awards') %}
{% if awards %}
## {{ T.awards }}
{% for item in awards %}- {{ item }}
{% endfor %}
{% endif %}
{% set talks = profile.custom_sections.get('talks') %}
{% if talks %}
## {{ T.talks }}
{% for item in talks %}- {{ item }}
{% endfor %}
{% endif %}
{% endif %}

{% if tailored_for %}
---
_{{ T.tailored_for }}: {{ tailored_for }}_
{% endif %}
