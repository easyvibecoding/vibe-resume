{# 简体中文简历 — 大厂友善默认（无照片、无政治面貌、无籍贯）。
   传统行业可后续 fork 一份 zh_CN_legacy 加这些字段。
   - 风格：名词短语 + 客观事实
   - 联系方式两行，避免单行过长
   - 技术堆栈分组展示
-#}
# {{ (profile | localized('name')) or profile.name }}
{% set _title = (profile | localized('title')) or profile.title %}
{% if _title %}**{{ _title }}**{% endif %}

{% set primary = [] -%}
{%- set _loc = (profile | localized('location')) or profile.location -%}
{%- if _loc %}{%- set _ = primary.append(_loc) %}{% endif %}
{%- if profile.email %}{%- set _ = primary.append(profile.email) %}{% endif %}
{%- if profile.phone %}{%- set _ = primary.append(profile.phone) %}{% endif %}
{{ primary | join('　|　') }}
{% set links = [] -%}
{%- if profile.linkedin %}{%- set _ = links.append('LinkedIn: ' ~ profile.linkedin) %}{% endif %}
{%- if profile.github %}{%- set _ = links.append('GitHub: ' ~ profile.github) %}{% endif %}
{%- if profile.website %}{%- set _ = links.append(profile.website) %}{% endif %}
{% if links %}{{ links | join('　|　') }}
{% endif %}

{% set _target = (profile | localized('target_role')) or profile.target_role %}
{% if _target %}> **{{ T.target_role }}**：{{ _target }}
{% endif %}

{% set _summary = (profile | localized('summary')) or profile.summary %}
{% if _summary %}
## {{ T.summary }}
{{ _summary | trim }}
{% endif %}

{% if skills_grouped %}
## {{ T.skills }}
{% for cat, items in skills_grouped.items() %}- **{{ cat }}**：{{ items | join('、') }}
{% endfor %}
{% endif %}

{% if profile.experience %}
## {{ T.experience }}

{% for e in profile.experience if e.title or e.company %}
### {{ e | localized('title') }}　|　{{ e | localized('company') }}
_{{ e.start | date }} – {{ e.end | date }}_

{% for b in (e | localized('bullets')) or [] %}- {{ b }}
{% endfor %}

{% endfor %}
{% endif %}

