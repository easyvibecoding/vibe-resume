<?xml version="1.0" encoding="UTF-16"?>
<!--
  Task Scheduler import template — runs scripts\backup_claude_projects.ps1 every
  Sunday at 03:00 local time. Before importing, edit the <Command> and
  <Arguments> paths (and the <Actions>/<WorkingDirectory>) so they point at the
  absolute location of the script on your machine.

  Import from GUI:
      Task Scheduler > Action > Import Task... > pick this file
  or CLI:
      schtasks /Create /TN "vibe-resume backup" /XML scripts\vibe-resume-backup.xml
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Weekly mirror of ~/.claude/projects to ~/ClaudeCodeArchive so vibe-resume has long-term session history even after the 30-day cleanup.</Description>
    <URI>\vibe-resume backup</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-04-26T03:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <DaysOfWeek>
          <Sunday />
        </DaysOfWeek>
        <WeeksInterval>1</WeeksInterval>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>true</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT1H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>pwsh</Command>
      <Arguments>-NoProfile -ExecutionPolicy Bypass -File "%USERPROFILE%\vibe-resume\scripts\backup_claude_projects.ps1"</Arguments>
      <WorkingDirectory>%USERPROFILE%\vibe-resume</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
